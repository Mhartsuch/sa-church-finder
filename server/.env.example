# Server Configuration
NODE_ENV=development
PORT=3001

# Client Configuration
CLIENT_URL=http://localhost:5173

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/sa_church_finder

# Session
SESSION_SECRET=your-secret-key-change-in-production
PASSWORD_RESET_TOKEN_TTL_MINUTES=60
AUTH_EXPOSE_RESET_PREVIEW=false
EMAIL_VERIFICATION_TOKEN_TTL_MINUTES=1440
AUTH_EXPOSE_VERIFICATION_PREVIEW=false

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# Email (for verification and notifications)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-email-password
SMTP_FROM=noreply@sachurchfinder.com

# AWS S3 (optional, for image storage)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET=sa-church-finder-uploads

# Logging
LOG_LEVEL=info

# Monitoring (optional)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=

# API Keys (if needed for external services)
MAPS_API_KEY=your-maps-api-key
