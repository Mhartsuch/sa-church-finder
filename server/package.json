    "cors": "^2",
    "dotenv": "^16",
    "express": "^4",
    "express-session": "^1",
    "helmet": "^7",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.4",
    "passport": "^0.7",
    "passport-google-oauth20": "^2",
