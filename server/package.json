    "@types/bcryptjs": "^2",
    "@types/connect-pg-simple": "^7",
    "@types/cors": "^2",
    "@types/express": "^4",
    "@types/express-session": "^1",
    "@types/jest": "^29",
    "@types/multer": "^2.1.0",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/passport": "^1",
    "@types/passport-google-oauth20": "^2",
    "@types/passport-local": "^1",
    "@types/supertest": "^7.2.0",
    "eslint": "^9.39.4",
    "globals": "^17.4.0",
    "jest": "^29",
    "nodemon": "^3",
    "prettier": "^3",
    "prisma": "^5.22.0",
    "supertest": "^7.2.2",
